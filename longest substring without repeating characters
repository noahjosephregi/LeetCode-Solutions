class Solution(object):
    def lengthOfLongestSubstring(self, s):
        """
        :type s: str
        :rtype: int
        """
        left = max_length = 0
        a = set()

        for right in range(len(s)):
            while s[right] in a:
                a.remove(s[left])
                left+=1
            a.add(s[right])
            max_length=max(max_length, right - left + 1)
        return max_length